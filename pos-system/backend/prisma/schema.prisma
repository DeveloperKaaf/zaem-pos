generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("CASHIER")
  sessions  Session[]
  shifts    Shift[]
  logs      ActionLog[]
  createdAt DateTime @default(now())
}

model Resource {
  id            String         @id @default(uuid())
  name          String
  type          String
  status        String         @default("AVAILABLE")

  tuyaDeviceId  String?
  tuyaSwitchCode String?       @default("switch_1")
  tuyaProductId String?
  tuyaUuid      String?

  prices        PriceConfig[]
  sessions      Session[]
  createdAt     DateTime       @default(now())
}

model PriceConfig {
  id          String   @id @default(uuid())
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  durationMin Int
  price       Float
}

model Session {
  id           String        @id @default(uuid())
  resourceId   String
  resource     Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  startTime    DateTime      @default(now())
  endTime      DateTime?
  durationMin  Int
  status       String        @default("ACTIVE")
  invoice      Invoice?
  createdAt    DateTime      @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  category  String?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  category    String
  date        DateTime @default(now())
  userId      String?
}

model Shift {
  id          String    @id @default(uuid())
  userId      String
  user         User      @relation(fields: [userId], references: [id])
  startTime   DateTime  @default(now())
  endTime     DateTime?
  floatAmount Float     @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Invoice {
  id            Int      @id @default(autoincrement())
  sessionId     String   @unique
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  timeAmount    Float    @default(0)
  itemsAmount   Float    @default(0)
  discount      Float    @default(0)
  discountType  String?  @default("FIXED")
  totalAmount   Float    @default(0)
  tax           Float    @default(0)
  isPaid        Boolean  @default(false)
  paymentDate   DateTime?
  paymentMethod String?
  cashAmount    Float    @default(0)
  netAmount     Float    @default(0)
  items         Json?
  createdAt     DateTime @default(now())
}

model ActionLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  timestamp DateTime @default(now())
}
